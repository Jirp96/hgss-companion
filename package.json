{
  "name": "hgss-companion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --require ./scripts/crypto-polyfill.cjs node_modules/vite/bin/vite.js",
    "build": "node --require ./scripts/crypto-polyfill.cjs node_modules/vite/bin/vite.js build",
    "preview": "node --require ./scripts/crypto-polyfill.cjs node_modules/vite/bin/vite.js preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "scrape": "node scripts/scrape.mjs",
    "test": "node --require ./scripts/crypto-polyfill.cjs node_modules/vitest/vitest.mjs run"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^2.5.3",
    "@tsconfig/svelte": "^5.0.2",
    "cheerio": "^1.0.0-rc.12",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "tslib": "^2.6.3",
    "typescript": "^5.5.4",
    "vite": "^4.5.5",
    "vitest": "^1.6.0"
  }
}
